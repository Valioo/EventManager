  "components": {
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "required": ["email", "fullName", "password"],
        "properties": {
          "fullName": { "type": "string", "minLength": 3, "description": "Required, min 3 characters" },
          "email": { "type": "string", "format": "email", "description": "Valid email address" },
          "password": { "type": "string", "minLength": 3, "description": "Required, min 3 characters" }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email", "description": "Valid email address" },
          "password": { "type": "string", "minLength": 3, "description": "Required, min 3 characters" }
        },
        "additionalProperties": false
      },
      "CategoryRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 3, "description": "Required, min 3 characters" }
        },
        "additionalProperties": false
      },
      "TagRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 3, "description": "Required, non-empty, min 3 characters" }
        },
        "additionalProperties": false
      },
      "CreateEventRequest": {
        "type": "object",
        "required": ["title", "description", "startDate", "endDate", "categoryId", "locationId"],
        "properties": {
          "title": { "type": "string", "minLength": 3, "description": "Required, min 3 characters" },
          "description": { "type": "string", "minLength": 3, "description": "Required, min 3 characters" },
          "startDate": { "type": "string", "format": "date-time", "description": "Required; must be before endDate" },
          "endDate": { "type": "string", "format": "date-time", "description": "Required; must be after startDate" },
          "categoryId": { "type": "integer", "format": "int32", "description": "Required" },
          "locationId": { "type": "integer", "format": "int32", "description": "Required" }
        },
        "additionalProperties": false
      },
      "UpdateEventRequest": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "minLength": 3, "nullable": true, "description": "If provided, min 3 characters" },
          "description": { "type": "string", "minLength": 3, "nullable": true, "description": "If provided, min 3 characters" },
          "startDate": { "type": "string", "format": "date-time", "nullable": true, "description": "If set with endDate, must be before endDate" },
          "endDate": { "type": "string", "format": "date-time", "nullable": true, "description": "If set with startDate, must be after startDate" },
          "categoryId": { "type": "integer", "format": "int32", "nullable": true },
          "locationId": { "type": "integer", "format": "int32", "nullable": true }
        },
        "additionalProperties": false
      },
      "CreateLocationRequest": {
        "type": "object",
        "required": ["address", "city", "venueName"],
        "properties": {
          "address": { "type": "string", "minLength": 3, "description": "Required, min 3 characters" },
          "city": { "type": "string", "minLength": 3, "description": "Required, min 3 characters" },
          "venueName": { "type": "string", "minLength": 3, "description": "Required, min 3 characters" }
        },
        "additionalProperties": false
      },
      "UpdateLocationRequest": {
        "type": "object",
        "properties": {
          "address": { "type": "string", "minLength": 3, "nullable": true, "description": "If provided, min 3 characters" },
          "city": { "type": "string", "minLength": 3, "nullable": true, "description": "If provided, min 3 characters" },
          "venueName": { "type": "string", "minLength": 3, "nullable": true, "description": "If provided, min 3 characters" }
        },
        "additionalProperties": false
      },
      "CreateTicketTypeRequest": {
        "type": "object",
        "required": ["name", "eventId", "price", "capacity"],
        "properties": {
          "name": { "type": "string", "minLength": 2, "description": "Required, min 2 characters" },
          "price": { "type": "number", "format": "double", "minimum": 0, "description": "Required, ≥ 0" },
          "capacity": { "type": "integer", "format": "int32", "minimum": 0, "description": "Required, ≥ 0" },
          "eventId": { "type": "integer", "format": "int32", "description": "Required" }
        },
        "additionalProperties": false
      },
      "UpdateTicketTypeRequest": {
        "type": "object",
        "properties": {
          "capacity": { "type": "integer", "format": "int32", "minimum": 0, "nullable": true, "description": "If provided, ≥ 0" }
        },
        "additionalProperties": false
      },
      "PurchaseTicketRequest": {
        "type": "object",
        "required": ["ticketTypeId"],
        "properties": {
          "ticketTypeId": { "type": "integer", "format": "int32", "description": "Required" }
        },
        "additionalProperties": false
      },
      "UpdateUserRequest": {
        "type": "object",
        "required": ["userId"],
        "properties": {
          "userId": { "type": "integer", "format": "int32", "description": "Required" },
          "email": { "type": "string", "format": "email", "nullable": true, "description": "If provided, must be valid email" },
          "fullName": { "type": "string", "minLength": 3, "nullable": true, "description": "If provided, min 3 characters" }
        },
        "additionalProperties": false
      },
      "CreateNotificationRequest": {
        "type": "object",
        "properties": {
          "daysPrior": { "type": "integer", "format": "int32" }
        },
        "additionalProperties": false
      },
      "EventNotificationRequest": {
        "type": "object",
        "properties": {
          "eventId": { "type": "integer", "format": "int32" },
          "notificationId": { "type": "integer", "format": "int32" }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Enter JWT token like: Bearer {your token}",
        "scheme": "Bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [{ "Bearer": [] }]
}
